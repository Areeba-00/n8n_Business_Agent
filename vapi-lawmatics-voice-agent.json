    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "// Normalize the incoming voice-platform tool/function call into ONE item.\n// Works with Vapi (message.toolCallList / message.toolCalls) and Retell ({ name, args }).\nconst root = $input.first().json || {};\nconst body = root.body || root;            // n8n nests webhook payloads under .body\nconst msg  = body.message || {};\n\n// --- Vapi shape ---\nconst calls = msg.toolCallList || msg.toolCalls || body.toolCalls || [];\nlet call = Array.isArray(calls) ? (calls[0] || {}) : {};\nlet fn   = call.function || {};\nlet toolCallId   = call.id || '';\nlet functionName = fn.name || '';\nlet args         = fn.arguments;\n\n// --- Retell shape (fallback) ---\nif (!functionName && body.name) {\n  functionName = body.name;\n  args = body.args;\n  toolCallId = (body.call && body.call.call_id) || '';\n}\n\n// arguments can arrive as a JSON string\nif (typeof args === 'string') {\n  try { args = JSON.parse(args); } catch (e) { args = {}; }\n}\nargs = args || {};\n\nreturn [{ json: { toolCallId, functionName, args, _raw: body } }];\n"
      },
      "id": "0fedb0c5-e813-49e4-a348-703bde38d4fa",
      "name": "Parse Tool Call",
