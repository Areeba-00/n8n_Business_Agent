    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "// Generate open business-hour slots for the requested date (no external dependency).\n// Tip: later, query Lawmatics Events for the date and remove already-booked times.\nconst args = ($input.first().json || {}).args || {};\n\nlet dateStr = (args.date || args.day || '').toString().trim();\nlet base;\nif (/^\\d{4}-\\d{2}-\\d{2}/.test(dateStr)) {\n  base = new Date(dateStr.slice(0, 10) + 'T12:00:00');\n} else {\n  base = new Date();\n  base.setDate(base.getDate() + 1); // default: tomorrow\n}\n\nconst weekday  = base.toLocaleDateString('en-US', { weekday: 'long' });\nconst niceDate = base.toLocaleDateString('en-US', { month: 'long', day: 'numeric' });\n\n// 9 AM, 11 AM, 2 PM\nconst startHours = [9, 11, 14];\nconst label = (h) => {\n  const ampm = h >= 12 ? 'PM' : 'AM';\n  const hr = ((h + 11) % 12) + 1;\n  return hr + ':00 ' + ampm;\n};\nconst slots = startHours.map(label);\nconst result = 'I have a few openings on ' + weekday + ', ' + niceDate +\n  ': ' + slots.join(', ') + '. Which time works best for you?';\n\nreturn [{ json: { result, date: base.toISOString().slice(0, 10), slots } }];\n"
      },
      "id": "d1d47948-f4bd-4dcc-b7c9-a6d55b58bb7d",
      "name": "Compute Available Slots",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        140
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "// Normalize booking arguments and compute ISO start/end times for Lawmatics.\nconst args = ($input.first().json || {}).args || {};\n\nconst fullName = (args.name || args.full_name || '').toString().trim();\nconst parts = fullName.split(/\\s+/).filter(Boolean);\nconst firstName = parts[0] || 'Unknown';\nconst lastName  = parts.slice(1).join(' ') || 'Caller';\n\nconst raw = (args.datetime || args.start_time || args.start || args.time || '').toString().trim();\nlet start = new Date(raw);\nif (isNaN(start.getTime())) {\n  start = new Date();\n  start.setDate(start.getDate() + 1);\n  start.setHours(10, 0, 0, 0); // fallback: tomorrow 10:00\n}\nconst durationMin = Number(args.duration_minutes || args.duration || 30) || 30;\nconst end = new Date(start.getTime() + durationMin * 60000);\n\nconst reason = (args.reason || args.matter || 'Consultation').toString();\n\nreturn [{\n  json: {\n    firstName,\n    lastName,\n    fullName: fullName || (firstName + ' ' + lastName),\n    email: args.email || '',\n    phone: args.phone || '',\n    reason,\n    startISO: start.toISOString(),\n    endISO:   end.toISOString(),\n    appointmentName: 'Consultation with ' + firstName + ' ' + lastName\n  }\n}];\n"
      },
