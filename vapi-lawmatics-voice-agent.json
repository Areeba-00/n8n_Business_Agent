    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "// Build the spoken confirmation string from the Lawmatics response.\nconst prep = $('Prepare Appointment Data').first().json || {};\nconst resp = $input.first().json || {};\n\nconst created = !!(resp && (resp.data || resp.id));\nconst apptId  = (resp.data && resp.data.id) || resp.id || null;\n\nlet when = prep.startISO;\ntry {\n  when = new Date(prep.startISO).toLocaleString('en-US', {\n    weekday: 'long', month: 'long', day: 'numeric',\n    hour: 'numeric', minute: '2-digit'\n  });\n} catch (e) {}\n\nlet result;\nif (created) {\n  result = 'Perfect, ' + prep.firstName + '. Your consultation is booked for ' + when +\n    '. We will send a confirmation to ' + (prep.email || 'your email') +\n    '. Is there anything else I can help you with?';\n} else {\n  result = 'Thanks ' + prep.firstName + '. I have noted your request for ' + when +\n    ', and our team will confirm shortly. Is there anything else I can help with?';\n}\n\nreturn [{ json: { result, appointmentId: apptId } }];\n"
      },
